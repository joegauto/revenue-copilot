# ===========================================
# Revenue Copilot — Engine (FastAPI)
# ===========================================

# Database
ENGINE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/revenue_copilot

# Redis
ENGINE_REDIS_URL=redis://localhost:6379/0

# LLM Provider
ENGINE_LLM_PROVIDER=openai
ENGINE_LLM_API_KEY=your-llm-api-key
ENGINE_LLM_MODEL=gpt-4o-mini

# Auth
ENGINE_JWT_SECRET=change-me-in-production

# WhatsApp Business API
ENGINE_WHATSAPP_API_TOKEN=your-whatsapp-api-token
ENGINE_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Google Calendar
ENGINE_GOOGLE_CLIENT_ID=your-google-client-id
ENGINE_GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
ENGINE_ENVIRONMENT=development
ENGINE_DEBUG=true
